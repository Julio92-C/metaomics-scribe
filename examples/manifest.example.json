{
  "manifest_version": "1.2",
  "study": {
    "id": "chicken_batch2",
    "name": "Chicken caecum microbiome — Dulse vs Control, weeks 4 and 5",
    "description": "Second chicken caecum dataset comparing Dulse-supplemented vs Control diets at two timepoints (week 4 and week 5). Exercises a random effect (block) and two negative controls.",
    "primary_group_col": "Treatment_Bird",
    "random_effect": "block",
    "fixed_effects": ["Treatment_Bird", "Weight"],
    "group_levels": ["Control_W4", "Control_W5", "Dulse_W4", "Dulse_W5"],
    "n_samples": 32,
    "n_controls": 2,
    "control_ids": ["CTRL1", "CTRL2"]
  },
  "config": {
    "filters": {
      "min_count_per_sample":  17,
      "min_count_for_species": 500,
      "min_prevalence_aldex":  2
    },
    "stats": {
      "permanova_permutations": 9999,
      "aldex_mc_samples":       128,
      "alpha":                  0.05
    }
  },
  "outputs": {
    "project_root": "../..",
    "datasets_dir": "test_run/Datasets",
    "figures_dir":  "test_run/Figures",
    "log_file":     "test_run/Reports/pipeline.log"
  },
